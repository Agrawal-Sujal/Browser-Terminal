{
  "manifest_version": 3,
  "name": "Browser Terminal",
  "version": "1.0",
  "description": "A terminal interface for your browser to quickly navigate via shortcuts.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"],
      "exclude_matches": [
        "*://chrome.google.com/webstore/*",
        "*://chromewebstore.google.com/*"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Open Settings"
  }
}
